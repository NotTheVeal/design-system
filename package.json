{
  "name": "@r_november24/react-ui-core",
  "version": "1.2.2",
  "description": "PartsSource React component library — design tokens, Tailwind utilities, and 57 production-ready components",
  "license": "MIT",
  "author": "PartsSource",
  "homepage": "https://partssourceinc.github.io/react-ui-core",
  "repository": {
    "type": "git",
    "url": "https://github.com/NotTheVeal/design-system.git"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./dist/style.css"
  },
  "files": [
    "dist",
    "src/components",
    "tokens"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "vite build --config vite.lib.config.ts",
    "build:tokens": "node style-dictionary.config.js",
    "validate": "node validate-references.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 50",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "serve-storybook": "serve storybook-static -l 6007"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@storybook/addon-essentials": "^8.0.0",
    "@storybook/react": "^8.0.0",
    "@storybook/react-vite": "^8.0.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "eslint": "^8.0.0",
    "eslint-plugin-jsx-a11y": "^6.0.0",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-hooks": "^4.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "jest-axe": "^8.0.0",
    "jsdom": "^24.0.0",
    "lucide-react": "^0.400.0",
    "serve": "^14.0.0",
    "storybook": "^8.0.0",
    "style-dictionary": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.0.0",
    "vitest": "^1.0.0"
  }
}
