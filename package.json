{
  "name": "@r_november24/react-ui-core",
  "version": "1.0.0",
  "description": "PartsSource React component library — design tokens, Tailwind utilities, and 57 production-ready components",
  "license": "MIT",
  "author": "PartsSource",
  "homepage": "https://partssourceinc.github.io/react-ui-core",
  "repository": {
    "type": "git",
    "url": "https://github.com/NotTheVeal/design-system.git"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./dist/style.css"
  },
  "files": [
    "dist",
    "src/components",
    "tokens"
  ],
  "sideEffects": ["*.css"],
  "scripts": {
    "build": "vite build --config vite.lib.config.ts",
    "build:tokens": "node style-dictionary.config.js",
    "validate": "node validate-references.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "style-dictionary": "^3.9.2",
    "token-transformer": "^0.0.33",
    "typescript": "^6.0.3",
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "vite-plugin-dts": "^3.0.0",
    "storybook": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-mcp": "^0.6.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
