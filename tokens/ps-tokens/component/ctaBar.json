{
  "ctaBar": {
    "color": {
      "background": {
        "default": { "$value": "{semantic.color.surface.default}", "$type": "color" },
        "sticky": { "$value": "{semantic.color.surface.default}", "$type": "color" }
      },
      "border": { "$value": "{semantic.color.border.subtle}", "$type": "color" },
      "text": {
        "primary": { "$value": "{semantic.color.text.primary}", "$type": "color" },
        "secondary": { "$value": "{semantic.color.text.secondary}", "$type": "color" }
      }
    },
    "spacing": {
      "paddingX": { "$value": "24px", "$type": "spacing" },
      "paddingY": { "$value": "16px", "$type": "spacing" },
      "buttonGap": { "$value": "12px", "$type": "spacing" }
    },
    "border": {
      "width": { "$value": "1px", "$type": "borderWidth" },
      "radius": { "$value": "{semantic.border.radius.md}", "$type": "borderRadius" }
    },
    "shadow": {
      "sticky": { "$value": "{semantic.shadow.lg}", "$type": "boxShadow" }
    },
    "sizing": {
      "minHeight": { "$value": "72px", "$type": "sizing" }
    }
  }
}




