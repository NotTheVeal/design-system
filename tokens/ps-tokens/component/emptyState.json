{
  "emptyState": {
    "$description": "Empty State — zero-data views with illustration, message, and optional CTA.",
    "background":    { "$value": "{semantic.color.surface.default}", "$type": "color" },
    "paddingV":      { "$value": "48px", "$type": "spacing" },
    "paddingH":      { "$value": "24px", "$type": "spacing" },
    "icon": {
      "size":        { "$value": "64px", "$type": "sizing" },
      "color":       { "$value": "{semantic.color.text.tertiary}", "$type": "color" }
    },
    "illustration": {
      "size":        { "$value": "120px", "$type": "sizing" }
    },
    "title": {
      "color":       { "$value": "{semantic.color.text.primary}", "$type": "color" },
      "fontSize":    { "$value": "18px", "$type": "fontSizes" },
      "fontWeight":  { "$value": "600", "$type": "fontWeights" },
      "marginT":     { "$value": "16px", "$type": "spacing" }
    },
    "body": {
      "color":       { "$value": "{semantic.color.text.secondary}", "$type": "color" },
      "fontSize":    { "$value": "14px", "$type": "fontSizes" },
      "fontWeight":  { "$value": "400", "$type": "fontWeights" },
      "maxWidth":    { "$value": "400px", "$type": "sizing" },
      "marginT":     { "$value": "8px", "$type": "spacing" }
    },
    "action": {
      "marginT":     { "$value": "24px", "$type": "spacing" },
      "gap":         { "$value": "12px", "$type": "spacing" }
    }
  }
}




