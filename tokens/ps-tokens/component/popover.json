{
  "popover": {
    "$description": "Popover — floating panel anchored to a trigger. Richer than tooltip; can contain actions.",
    "background":    { "$value": "{semantic.color.surface.default}", "$type": "color" },
    "border":        { "$value": "{semantic.color.border.default}", "$type": "color" },
    "borderWidth":   { "$value": "1px", "$type": "borderWidth" },
    "radius":        { "$value": "8px", "$type": "borderRadius" },
    "shadow":        { "$value": "{primitive.shadow.lg}", "$type": "boxShadow" },
    "zIndex":        { "$value": "300", "$type": "other" },
    "minWidth":      { "$value": "200px", "$type": "sizing" },
    "maxWidth":      { "$value": "320px", "$type": "sizing" },
    "paddingV":      { "$value": "16px", "$type": "spacing" },
    "paddingH":      { "$value": "16px", "$type": "spacing" },
    "header": {
      "fontSize":    { "$value": "14px", "$type": "fontSizes" },
      "fontWeight":  { "$value": "600", "$type": "fontWeights" },
      "color":       { "$value": "{semantic.color.text.primary}", "$type": "color" },
      "marginB":     { "$value": "8px", "$type": "spacing" }
    },
    "body": {
      "fontSize":    { "$value": "13px", "$type": "fontSizes" },
      "color":       { "$value": "{semantic.color.text.secondary}", "$type": "color" }
    },
    "arrow": {
      "size":        { "$value": "8px", "$type": "sizing" },
      "color":       { "$value": "{semantic.color.surface.default}", "$type": "color" },
      "borderColor": { "$value": "{semantic.color.border.default}", "$type": "color" }
    },
    "animation": {
      "duration":    { "$value": "150ms", "$type": "other" },
      "easing":      { "$value": "ease", "$type": "other" }
    }
  }
}




