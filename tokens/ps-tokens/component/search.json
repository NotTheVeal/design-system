{
  "search": {
    "$description": "Search Bar — 5 variants: global (top nav), inline (card/list), within (filter facet), collapsed (icon-only), srp (search results page)",

    "global": {
      "$description": "Global search — top nav, queries entire catalog. 40px input + 48px submit button.",
      "height": { "$value": "40px", "$type": "sizing" },
      "radius": { "$value": "4px", "$type": "borderRadius" },
      "background": { "$value": "{semantic.color.surface.default}", "$type": "color" },
      "border": {
        "default": { "$value": "{primitive.color.neutral.300}", "$type": "color", "$description": "#DCDCDC" },
        "hover":   { "$value": "{primitive.color.neutral.400}", "$type": "color", "$description": "#999" },
        "focus":   { "$value": "{semantic.color.brand.primary}", "$type": "color", "$description": "#005BA6" },
        "error":   { "$value": "{semantic.color.feedback.error}", "$type": "color" },
        "width":   { "$value": "1px", "$type": "borderWidth" }
      },
      "focusRing": { "$value": "0 0 0 3px rgba(0,91,166,0.18)", "$type": "boxShadow" },
      "text": {
        "placeholder": { "$value": "{semantic.color.text.tertiary}", "$type": "color" },
        "value":       { "$value": "{semantic.color.text.primary}", "$type": "color" }
      },
      "icon": {
        "color":   { "$value": "{semantic.color.text.secondary}", "$type": "color" },
        "size":    { "$value": "18px", "$type": "sizing" }
      },
      "paddingX": { "$value": "12px", "$type": "spacing" },
      "submit": {
        "$description": "Orange submit button — right-side, 48px wide",
        "width":            { "$value": "48px", "$type": "sizing" },
        "height":           { "$value": "40px", "$type": "sizing" },
        "background":       { "$value": "{primitive.color.orange.500}", "$type": "color", "$description": "#FF9505" },
        "backgroundHover":  { "$value": "{primitive.color.orange.600}", "$type": "color", "$description": "#E88500" },
        "icon":             { "$value": "{semantic.color.surface.default}", "$type": "color" },
        "radius":           { "$value": "0 4px 4px 0", "$type": "borderRadius" }
      }
    },

    "inline": {
      "$description": "Inline search — card/page context (Asset Inventory, list views). 40px, transparent icon button, no submit.",
      "height":     { "$value": "40px", "$type": "sizing" },
      "width":      { "$value": "320px", "$type": "sizing" },
      "radius":     { "$value": "4px", "$type": "borderRadius" },
      "background": { "$value": "{semantic.color.surface.default}", "$type": "color" },
      "border": {
        "default": { "$value": "{primitive.color.neutral.300}", "$type": "color" },
        "hover":   { "$value": "{primitive.color.neutral.400}", "$type": "color" },
        "focus":   { "$value": "{semantic.color.brand.primary}", "$type": "color" },
        "width":   { "$value": "1px", "$type": "borderWidth" }
      },
      "focusRing": { "$value": "0 0 0 3px rgba(0,91,166,0.18)", "$type": "boxShadow" },
      "text": {
        "placeholder": { "$value": "{semantic.color.text.tertiary}", "$type": "color" },
        "value":       { "$value": "{semantic.color.text.primary}", "$type": "color" }
      },
      "iconButton": {
        "$description": "Transparent icon button, 42px, left-aligned",
        "width":      { "$value": "42px", "$type": "sizing" },
        "background": { "$value": "transparent", "$type": "color" },
        "icon":       { "$value": "{semantic.color.text.secondary}", "$type": "color" },
        "iconFocus":  { "$value": "{semantic.color.brand.primary}", "$type": "color" }
      },
      "paddingX": { "$value": "44px", "$type": "spacing", "$description": "Left padding accommodates icon button" }
    },

    "within": {
      "$description": "Search-within — filter facet / long dropdown lists. 32px, right-side glyph, no submit button.",
      "height":     { "$value": "32px", "$type": "sizing" },
      "width":      { "$value": "240px", "$type": "sizing" },
      "radius":     { "$value": "3px", "$type": "borderRadius" },
      "background": { "$value": "{semantic.color.surface.default}", "$type": "color" },
      "border": {
        "default": { "$value": "{primitive.color.neutral.300}", "$type": "color" },
        "hover":   { "$value": "{primitive.color.neutral.400}", "$type": "color" },
        "focus":   { "$value": "{semantic.color.brand.primary}", "$type": "color" },
        "width":   { "$value": "1px", "$type": "borderWidth" }
      },
      "text": {
        "placeholder": { "$value": "{semantic.color.text.tertiary}", "$type": "color" },
        "value":       { "$value": "{semantic.color.text.primary}", "$type": "color" },
        "size":        { "$value": "13px", "$type": "fontSizes" }
      },
      "glyph": {
        "$description": "Search glyph inside the stroke on right side",
        "color":        { "$value": "{semantic.color.text.tertiary}", "$type": "color" },
        "colorActive":  { "$value": "{semantic.color.brand.primary}", "$type": "color" },
        "size":         { "$value": "16px", "$type": "sizing" },
        "marginRight":  { "$value": "8px", "$type": "spacing" }
      },
      "paddingX": { "$value": "8px", "$type": "spacing" },
      "paddingRight": { "$value": "28px", "$type": "spacing", "$description": "Makes room for right glyph" }
    },

    "collapsed": {
      "$description": "Collapsed / icon-only — dense headers like My Lists. 36×36 transparent button, expands on click.",
      "size":             { "$value": "36px", "$type": "sizing" },
      "radius":           { "$value": "4px", "$type": "borderRadius" },
      "background":       { "$value": "transparent", "$type": "color" },
      "backgroundHover":  { "$value": "{primitive.color.neutral.100}", "$type": "color", "$description": "#F4F6F8" },
      "icon":             { "$value": "{semantic.color.text.secondary}", "$type": "color" },
      "iconHover":        { "$value": "{semantic.color.brand.primary}", "$type": "color" },
      "transition":       { "$value": "200ms ease", "$type": "other" }
    },

    "srp": {
      "$description": "Search Results Page search — sits with Categories header. 40px, 5px radius, #CCCCCC border, orange button.",
      "height":     { "$value": "40px", "$type": "sizing" },
      "radius":     { "$value": "5px", "$type": "borderRadius" },
      "background": { "$value": "{semantic.color.surface.default}", "$type": "color" },
      "border": {
        "default": { "$value": "{primitive.color.neutral.300}", "$type": "color", "$description": "#CCCCCC" },
        "hover":   { "$value": "{primitive.color.neutral.400}", "$type": "color" },
        "focus":   { "$value": "{semantic.color.brand.primary}", "$type": "color" },
        "width":   { "$value": "1px", "$type": "borderWidth" }
      },
      "text": {
        "placeholder": { "$value": "{semantic.color.text.tertiary}", "$type": "color" },
        "value":       { "$value": "{semantic.color.text.primary}", "$type": "color" }
      },
      "submit": {
        "width":           { "$value": "48px", "$type": "sizing" },
        "background":      { "$value": "{primitive.color.orange.500}", "$type": "color" },
        "backgroundHover": { "$value": "{primitive.color.orange.600}", "$type": "color" },
        "icon":            { "$value": "{semantic.color.surface.default}", "$type": "color" },
        "radius":          { "$value": "0 5px 5px 0", "$type": "borderRadius" }
      }
    },

    "typeahead": {
      "$description": "Typeahead / autocomplete dropdown — shared across global + inline variants",
      "background":  { "$value": "{semantic.color.surface.default}", "$type": "color" },
      "border":      { "$value": "{primitive.color.neutral.300}", "$type": "color" },
      "borderWidth": { "$value": "1px", "$type": "borderWidth" },
      "radius":      { "$value": "4px", "$type": "borderRadius" },
      "shadow":      { "$value": "0 8px 24px rgba(0,47,72,0.10)", "$type": "boxShadow" },
      "zIndex":      { "$value": "200", "$type": "other" },
      "row": {
        "category": {
          "height":     { "$value": "44px", "$type": "sizing" },
          "background": { "$value": "{semantic.color.surface.default}", "$type": "color" },
          "backgroundHover": { "$value": "{primitive.color.neutral.50}", "$type": "color" },
          "text":       { "$value": "{semantic.color.text.secondary}", "$type": "color" },
          "textSize":   { "$value": "12px", "$type": "fontSizes" },
          "paddingX":   { "$value": "16px", "$type": "spacing" }
        },
        "product": {
          "height":     { "$value": "54px", "$type": "sizing" },
          "background": { "$value": "{semantic.color.surface.default}", "$type": "color" },
          "backgroundHover": { "$value": "{primitive.color.neutral.50}", "$type": "color" },
          "text":       { "$value": "{semantic.color.text.primary}", "$type": "color" },
          "textSize":   { "$value": "14px", "$type": "fontSizes" },
          "subText":    { "$value": "{semantic.color.text.secondary}", "$type": "color" },
          "paddingX":   { "$value": "16px", "$type": "spacing" },
          "imageSize":  { "$value": "36px", "$type": "sizing" }
        }
      },
      "highlight":    { "$value": "{semantic.color.brand.primary}", "$type": "color" },
      "divider":      { "$value": "{primitive.color.neutral.200}", "$type": "color" }
    },

    "shared": {
      "$description": "Tokens shared across all search variants",
      "transition":   { "$value": "150ms ease", "$type": "other" },
      "fontFamily":   { "$value": "Source Sans Pro", "$type": "fontFamilies" },
      "fontSize":     { "$value": "14px", "$type": "fontSizes" },
      "fontWeight":   { "$value": "400", "$type": "fontWeights" },
      "disabled": {
        "background": { "$value": "{semantic.color.surface.disabled}", "$type": "color" },
        "border":     { "$value": "{primitive.color.neutral.200}", "$type": "color" },
        "text":       { "$value": "{semantic.color.text.disabled}", "$type": "color" },
        "opacity":    { "$value": "0.5", "$type": "opacity" }
      }
    }
  }
}

