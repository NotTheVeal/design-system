{
  "metric": {
    "color": {
      "value": { "$value": "{semantic.color.text.primary}", "$type": "color" },
      "label": { "$value": "{semantic.color.text.secondary}", "$type": "color" },
      "trend": {
        "positive": { "$value": "{semantic.color.feedback.success.DEFAULT}", "$type": "color" },
        "negative": { "$value": "{semantic.color.feedback.error.DEFAULT}", "$type": "color" },
        "neutral": { "$value": "{semantic.color.text.secondary}", "$type": "color" }
      },
      "background": { "$value": "{semantic.color.surface.default}", "$type": "color" },
      "border": { "$value": "{semantic.color.border.default}", "$type": "color" }
    },
    "typography": {
      "value": {
        "fontSize": { "$value": "{semantic.typography.display.sm.fontSize}", "$type": "fontSizes" },
        "fontWeight": { "$value": "{primitive.typography.fontWeight.bold}", "$type": "fontWeights" }
      },
      "label": {
        "fontSize": { "$value": "{semantic.typography.body.sm.fontSize}", "$type": "fontSizes" },
        "fontWeight": { "$value": "{primitive.typography.fontWeight.regular}", "$type": "fontWeights" }
      },
      "trend": {
        "fontSize": { "$value": "{semantic.typography.body.xs.fontSize}", "$type": "fontSizes" }
      }
    },
    "spacing": {
      "padding": { "$value": "16px", "$type": "spacing" },
      "gap": { "$value": "4px", "$type": "spacing" }
    },
    "border": {
      "radius": { "$value": "{semantic.border.radius.md}", "$type": "borderRadius" },
      "width": { "$value": "1px", "$type": "borderWidth" }
    }
  }
}


