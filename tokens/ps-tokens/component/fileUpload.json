{
  "fileUpload": {
    "$description": "File Upload — drag-and-drop zone and file attachment input.",
    "zone": {
      "background":        { "$value": "{primitive.color.neutral.50}", "$type": "color" },
      "backgroundHover":   { "$value": "{semantic.color.brand.tint}", "$type": "color" },
      "backgroundActive":  { "$value": "{semantic.color.brand.tint}", "$type": "color" },
      "border":            { "$value": "{semantic.color.border.default}", "$type": "color" },
      "borderHover":       { "$value": "{semantic.color.brand.primary}", "$type": "color" },
      "borderStyle":       { "$value": "dashed", "$type": "other" },
      "borderWidth":       { "$value": "2px", "$type": "borderWidth" },
      "radius":            { "$value": "8px", "$type": "borderRadius" },
      "paddingV":          { "$value": "32px", "$type": "spacing" },
      "paddingH":          { "$value": "24px", "$type": "spacing" },
      "icon":              { "$value": "{semantic.color.text.tertiary}", "$type": "color" },
      "iconHover":         { "$value": "{semantic.color.brand.primary}", "$type": "color" },
      "iconSize":          { "$value": "40px", "$type": "sizing" },
      "text":              { "$value": "{semantic.color.text.secondary}", "$type": "color" },
      "textEmphasis":      { "$value": "{semantic.color.brand.primary}", "$type": "color" }
    },
    "fileItem": {
      "background":        { "$value": "{primitive.color.neutral.50}", "$type": "color" },
      "border":            { "$value": "{semantic.color.border.default}", "$type": "color" },
      "borderWidth":       { "$value": "1px", "$type": "borderWidth" },
      "radius":            { "$value": "4px", "$type": "borderRadius" },
      "paddingV":          { "$value": "8px", "$type": "spacing" },
      "paddingH":          { "$value": "12px", "$type": "spacing" },
      "icon":              { "$value": "{semantic.color.brand.primary}", "$type": "color" },
      "nameText":          { "$value": "{semantic.color.text.primary}", "$type": "color" },
      "metaText":          { "$value": "{semantic.color.text.tertiary}", "$type": "color" },
      "removeIcon":        { "$value": "{semantic.color.text.secondary}", "$type": "color" },
      "removeIconHover":   { "$value": "{semantic.color.feedback.error.DEFAULT}", "$type": "color" }
    },
    "error": {
      "border":            { "$value": "{semantic.color.feedback.error.DEFAULT}", "$type": "color" },
      "text":              { "$value": "{semantic.color.feedback.error.DEFAULT}", "$type": "color" }
    }
  }
}



