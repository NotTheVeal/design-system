{
  "stepper": {
    "$description": "Stepper \u2014 4 Figma component sets: bar, Indicator, Step, (Stepper wrapper)",
    "bar": {
      "$description": "Connector bar between steps",
      "default": {
        "$value": "{semantic.color.text.secondary}",
        "$type": "color"
      },
      "complete": {
        "$value": "{semantic.color.feedback.success.DEFAULT}",
        "$type": "color"
      },
      "height": {
        "$value": "2px",
        "$type": "dimension"
      }
    },
    "indicator": {
      "$description": "Step circle indicator \u2014 Finished/Current/Future",
      "size": {
        "$value": "32px",
        "$type": "dimension"
      },
      "radius": {
        "$value": "100px",
        "$type": "borderRadius"
      },
      "finished": {
        "background": {
          "$value": "{semantic.color.feedback.success.DEFAULT}",
          "$type": "color"
        },
        "border": {
          "$value": "{semantic.color.feedback.success.DEFAULT}",
          "$type": "color"
        },
        "checkmark": {
          "$value": "{semantic.color.feedback.success.DEFAULT}",
          "$type": "color"
        },
        "text": {
          "$value": "{semantic.color.surface.default}",
          "$type": "color"
        }
      },
      "current": {
        "background": {
          "$value": "{semantic.color.surface.default}",
          "$type": "color"
        },
        "border": {
          "$value": "{semantic.color.feedback.success.DEFAULT}",
          "$type": "color"
        },
        "text": {
          "$value": "{semantic.color.feedback.success.DEFAULT}",
          "$type": "color"
        },
        "shadow": {
          "$value": "0 0 0 3px rgba(23,171,120,0.2)",
          "$type": "boxShadow"
        }
      },
      "future": {
        "background": {
          "$value": "{semantic.color.surface.default}",
          "$type": "color"
        },
        "border": {
          "$value": "{semantic.color.text.secondary}",
          "$type": "color"
        },
        "text": {
          "$value": "{semantic.color.text.secondary}",
          "$type": "color"
        }
      }
    },
    "step": {
      "$description": "Full step = indicator + label + connector bar. Property 1=position (Start/End), Property 2=state (Start/Current/Finished)",
      "label": {
        "current": {
          "$value": "{semantic.color.text.primary}",
          "$type": "color"
        },
        "finished": {
          "$value": "{semantic.color.text.primary}",
          "$type": "color"
        },
        "future": {
          "$value": "{semantic.color.text.secondary}",
          "$type": "color"
        }
      },
      "connector": {
        "incomplete": {
          "$value": "{semantic.color.text.secondary}",
          "$type": "color"
        },
        "complete": {
          "$value": "{semantic.color.feedback.success.DEFAULT}",
          "$type": "color"
        }
      }
    },
    "container": {
      "background": {
        "$value": "{semantic.color.surface.default}",
        "$type": "color"
      },
      "padding": {
        "$value": "24px",
        "$type": "dimension"
      }
    },
    "paddingV": {
      "$value": "24px",
      "$type": "dimension"
    },
    "paddingH": {
      "$value": "24px",
      "$type": "dimension"
    },
    "gap": {
      "$value": "8px",
      "$type": "dimension"
    },
    "indicatorSize": {
      "$value": "32px",
      "$type": "dimension"
    },
    "connectorHeight": {
      "$value": "2px",
      "$type": "dimension"
    },
    "labelTypography": {
      "$value": {
        "fontFamily": "Source Sans Pro",
        "fontWeight": 400,
        "fontSize": "14px",
        "lineHeight": "20px"
      },
      "$type": "typography"
    },
    "stepNumberTypography": {
      "$value": {
        "fontFamily": "Source Sans Pro",
        "fontWeight": 600,
        "fontSize": "14px",
        "lineHeight": "20px"
      },
      "$type": "typography"
    }
  }
}
