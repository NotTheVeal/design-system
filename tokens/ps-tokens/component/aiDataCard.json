{
  "aiDataCard": {
    "color": {
      "background": {
        "default": { "$value": "#F5F5F5", "$type": "color" },
        "hover": { "$value": "#E6F2FF", "$type": "color" }
      },
      "border": {
        "default": { "$value": "#E5E5E5", "$type": "color" },
        "hover": { "$value": "#CCE5FF", "$type": "color" }
      },
      "text": {
        "title": { "$value": "#4A4A4A", "$type": "color" },
        "manufacturer": { "$value": "#777777", "$type": "color" },
        "tracking": { "$value": "#005BA6", "$type": "color" },
        "costLabel": { "$value": "#949494", "$type": "color" },
        "costAmount": { "$value": "#4A4A4A", "$type": "color" }
      },
      "divider": { "$value": "#E5E5E5", "$type": "color" }
    },
    "sizing": {
      "width": { "$value": "348px", "$type": "sizing" },
      "imageArea": { "$value": "100px", "$type": "sizing" }
    },
    "spacing": {
      "padding": { "$value": "16px", "$type": "spacing" },
      "gap": { "$value": "8px", "$type": "spacing" },
      "dividerMargin": { "$value": "12px", "$type": "spacing" }
    },
    "border": {
      "radius": { "$value": "8px", "$type": "borderRadius" },
      "width": { "$value": "1px", "$type": "borderWidth" }
    },
    "shadow": {
      "default": { "$value": "0 4px 12px rgba(0,0,0,0.04)", "$type": "boxShadow" }
    },
    "typography": {
      "title": {
        "fontSize": { "$value": "16px", "$type": "fontSizes" },
        "fontWeight": { "$value": "700", "$type": "fontWeights" }
      },
      "manufacturer": {
        "fontSize": { "$value": "14px", "$type": "fontSizes" },
        "fontWeight": { "$value": "400", "$type": "fontWeights" }
      },
      "tracking": {
        "fontSize": { "$value": "14px", "$type": "fontSizes" },
        "fontWeight": { "$value": "600", "$type": "fontWeights" }
      },
      "costLabel": {
        "fontSize": { "$value": "14px", "$type": "fontSizes" }
      },
      "costAmount": {
        "fontSize": { "$value": "16px", "$type": "fontSizes" },
        "fontWeight": { "$value": "700", "$type": "fontWeights" }
      }
    }
  }
}



