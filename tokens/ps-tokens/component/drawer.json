{
  "drawer": {
    "$description": "Drawer / Sheet — slides in from right. Widths: Narrow 320px, Default 480px, Wide 600px.",
    "background":  { "$value": "{semantic.color.surface.default}", "$type": "color" },
    "overlay":     { "$value": "rgba(0,47,72,0.40)", "$type": "color" },
    "border":      { "$value": "{semantic.color.border.default}", "$type": "color" },
    "borderWidth": { "$value": "1px", "$type": "borderWidth" },
    "shadow":      { "$value": "{primitive.shadow.xl}", "$type": "boxShadow" },
    "radius":      { "$value": "0", "$type": "borderRadius" },
    "zIndex":      { "$value": "400", "$type": "other" },
    "width": {
      "narrow":  { "$value": "320px", "$type": "sizing" },
      "default": { "$value": "480px", "$type": "sizing" },
      "wide":    { "$value": "600px", "$type": "sizing" }
    },
    "header": {
      "height":     { "$value": "64px", "$type": "sizing" },
      "paddingH":   { "$value": "24px", "$type": "spacing" },
      "background": { "$value": "{semantic.color.surface.default}", "$type": "color" },
      "border":     { "$value": "{semantic.color.border.default}", "$type": "color" },
      "title": {
        "color":      { "$value": "{semantic.color.text.primary}", "$type": "color" },
        "fontSize":   { "$value": "18px", "$type": "fontSizes" },
        "fontWeight": { "$value": "600", "$type": "fontWeights" }
      },
      "close": {
        "color":      { "$value": "{semantic.color.text.secondary}", "$type": "color" },
        "colorHover": { "$value": "{semantic.color.brand.primary}", "$type": "color" },
        "size":       { "$value": "24px", "$type": "sizing" }
      }
    },
    "body": {
      "paddingH": { "$value": "24px", "$type": "spacing" },
      "paddingV": { "$value": "24px", "$type": "spacing" }
    },
    "footer": {
      "height":   { "$value": "72px", "$type": "sizing" },
      "paddingH": { "$value": "24px", "$type": "spacing" },
      "border":   { "$value": "{semantic.color.border.default}", "$type": "color" },
      "gap":      { "$value": "12px", "$type": "spacing" }
    },
    "animation": {
      "duration": { "$value": "250ms", "$type": "other" },
      "easing":   { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "other" }
    }
  }
}

