{
  "status": {
    "color": {
      "active": {
        "background": { "$value": "{semantic.color.feedback.successLight}", "$type": "color" },
        "text": { "$value": "{semantic.color.feedback.success}", "$type": "color" },
        "dot": { "$value": "{semantic.color.feedback.success}", "$type": "color" }
      },
      "inactive": {
        "background": { "$value": "{semantic.color.surface.muted}", "$type": "color" },
        "text": { "$value": "{semantic.color.text.secondary}", "$type": "color" },
        "dot": { "$value": "{semantic.color.text.disabled}", "$type": "color" }
      },
      "warning": {
        "background": { "$value": "{semantic.color.feedback.warningLight}", "$type": "color" },
        "text": { "$value": "{semantic.color.feedback.warning}", "$type": "color" },
        "dot": { "$value": "{semantic.color.feedback.warning}", "$type": "color" }
      },
      "error": {
        "background": { "$value": "{semantic.color.feedback.errorLight}", "$type": "color" },
        "text": { "$value": "{semantic.color.feedback.error}", "$type": "color" },
        "dot": { "$value": "{semantic.color.feedback.error}", "$type": "color" }
      },
      "info": {
        "background": { "$value": "{semantic.color.feedback.infoLight}", "$type": "color" },
        "text": { "$value": "{semantic.color.feedback.info}", "$type": "color" },
        "dot": { "$value": "{semantic.color.feedback.info}", "$type": "color" }
      }
    },
    "border": {
      "radius": { "$value": "30px", "$type": "borderRadius" }
    },
    "spacing": {
      "paddingX": { "$value": "8px", "$type": "spacing" },
      "paddingY": { "$value": "3px", "$type": "spacing" },
      "gap": { "$value": "4px", "$type": "spacing" }
    },
    "typography": {
      "fontSize": { "$value": "{semantic.typography.body.xs.fontSize}", "$type": "fontSizes" },
      "fontWeight": { "$value": "{primitive.typography.fontWeight.semibold}", "$type": "fontWeights" }
    },
    "dot": {
      "size": { "$value": "6px", "$type": "sizing" }
    }
  }
}

