{
  "tabs": {
    "$description": "Tabs — horizontal navigation within a page section. PS Figma: ' Tabs' page.",
    "height":     { "$value": "44px", "$type": "sizing" },
    "border": {
      "color":      { "$value": "{semantic.color.border.default}", "$type": "color" },
      "width":      { "$value": "1px", "$type": "borderWidth" }
    },
    "indicator": {
      "color":      { "$value": "{semantic.color.brand.primary}", "$type": "color" },
      "height":     { "$value": "2px", "$type": "sizing" }
    },
    "item": {
      "paddingH":   { "$value": "16px", "$type": "spacing" },
      "gap":        { "$value": "0", "$type": "spacing" },
      "background": {
        "default":  { "$value": "transparent", "$type": "color" },
        "hover":    { "$value": "{primitive.color.neutral.50}", "$type": "color" },
        "active":   { "$value": "transparent", "$type": "color" },
        "disabled": { "$value": "transparent", "$type": "color" }
      },
      "text": {
        "default":   { "$value": "{semantic.color.text.secondary}", "$type": "color" },
        "hover":     { "$value": "{semantic.color.brand.primary}", "$type": "color" },
        "active":    { "$value": "{semantic.color.brand.primary}", "$type": "color" },
        "disabled":  { "$value": "{semantic.color.text.disabled}", "$type": "color" },
        "fontSize":  { "$value": "14px", "$type": "fontSizes" },
        "fontWeight":{ "$value": "600", "$type": "fontWeights" },
        "fontWeightDefault": { "$value": "400", "$type": "fontWeights" }
      },
      "badge": {
        "background": { "$value": "{primitive.color.neutral.200}", "$type": "color" },
        "backgroundActive": { "$value": "{semantic.color.brand.tint}", "$type": "color" },
        "text":       { "$value": "{semantic.color.text.secondary}", "$type": "color" },
        "textActive": { "$value": "{semantic.color.brand.primary}", "$type": "color" },
        "radius":     { "$value": "100px", "$type": "borderRadius" },
        "paddingH":   { "$value": "6px", "$type": "spacing" },
        "height":     { "$value": "18px", "$type": "sizing" },
        "fontSize":   { "$value": "11px", "$type": "fontSizes" }
      }
    },
    "panel": {
      "paddingV":   { "$value": "24px", "$type": "spacing" },
      "paddingH":   { "$value": "0px", "$type": "spacing" }
    }
  }
}






