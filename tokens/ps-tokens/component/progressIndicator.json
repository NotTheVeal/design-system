{
  "progressIndicator": {
    "$description": "Progress Indicator — linear bar and circular spinner variants.",
    "bar": {
      "height":          { "$value": "8px", "$type": "sizing" },
      "heightThin":      { "$value": "4px", "$type": "sizing" },
      "radius":          { "$value": "100px", "$type": "borderRadius" },
      "background":      { "$value": "{primitive.color.neutral.200}", "$type": "color", "$description": "Track background" },
      "fill":            { "$value": "{semantic.color.brand.primary}", "$type": "color" },
      "fillSuccess":     { "$value": "{semantic.color.feedback.success.DEFAULT}", "$type": "color" },
      "fillWarning":     { "$value": "{semantic.color.feedback.warning.DEFAULT}", "$type": "color" },
      "fillDanger":      { "$value": "{semantic.color.feedback.error.DEFAULT}", "$type": "color" },
      "animation": {
        "duration": { "$value": "400ms", "$type": "other" },
        "easing":   { "$value": "ease-out", "$type": "other" }
      }
    },
    "spinner": {
      "size": {
        "sm": { "$value": "16px", "$type": "sizing" },
        "md": { "$value": "24px", "$type": "sizing" },
        "lg": { "$value": "40px", "$type": "sizing" }
      },
      "color":       { "$value": "{semantic.color.brand.primary}", "$type": "color" },
      "colorTrack":  { "$value": "{primitive.color.neutral.200}", "$type": "color" },
      "strokeWidth": { "$value": "2px", "$type": "borderWidth" },
      "animation": {
        "duration": { "$value": "700ms", "$type": "other" },
        "easing":   { "$value": "linear", "$type": "other" }
      }
    },
    "label": {
      "color":      { "$value": "{semantic.color.text.secondary}", "$type": "color" },
      "fontSize":   { "$value": "13px", "$type": "fontSizes" },
      "fontWeight": { "$value": "400", "$type": "fontWeights" },
      "gap":        { "$value": "8px", "$type": "spacing" }
    },
    "steps": {
      "$description": "Multi-step progress (Step Progress component)",
      "complete": {
        "background": { "$value": "{semantic.color.brand.primary}", "$type": "color" },
        "border":     { "$value": "{semantic.color.brand.primary}", "$type": "color" },
        "icon":       { "$value": "{semantic.color.surface.default}", "$type": "color" }
      },
      "active": {
        "background": { "$value": "{semantic.color.surface.default}", "$type": "color" },
        "border":     { "$value": "{semantic.color.brand.primary}", "$type": "color" },
        "text":       { "$value": "{semantic.color.brand.primary}", "$type": "color" }
      },
      "inactive": {
        "background": { "$value": "{primitive.color.neutral.200}", "$type": "color" },
        "border":     { "$value": "{primitive.color.neutral.300}", "$type": "color" },
        "text":       { "$value": "{semantic.color.text.tertiary}", "$type": "color" }
      },
      "connector": {
        "color":  { "$value": "{primitive.color.neutral.300}", "$type": "color" },
        "colorComplete": { "$value": "{semantic.color.brand.primary}", "$type": "color" },
        "height": { "$value": "2px", "$type": "sizing" }
      },
      "nodeSize": { "$value": "32px", "$type": "sizing" }
    }
  }
}





