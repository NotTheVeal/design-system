{
  "navTop": {
    "$description": "Top Navigation bar — blue header. Figma: Navigation/TopNav. Contains: logo, search, cart, notifications, user account.",

    "container": {
      "background": {
        "$value": "{semantic.color.brand.primary}",
        "$type": "color",
        "$description": "Brand blue top bar background"
      },
      "borderBottom": {
        "$value": "{semantic.color.interactive.hoverDark}",
        "$type": "color",
        "$description": "Subtle bottom edge separator"
      },
      "height": {
        "$value": "64px",
        "$type": "dimension"
      },
      "paddingH": {
        "$value": "24px",
        "$type": "dimension"
      },
      "gap": {
        "$value": "16px",
        "$type": "dimension",
        "$description": "Space between top nav elements"
      }
    },

    "logo": {
      "$description": "PartsSource logo / wordmark area",
      "text": {
        "$value": "{semantic.color.surface.default}",
        "$type": "color"
      },
      "icon": {
        "$value": "{semantic.color.surface.default}",
        "$type": "color"
      },
      "typography": {
        "$value": {
          "fontFamily": "Source Sans Pro",
          "fontWeight": 400,
          "fontSize": "24px",
          "lineHeight": "32px"
        },
        "$type": "typography"
      }
    },

    "search": {
      "$description": "Search bar in top nav",
      "background": {
        "$value": "{semantic.color.interactive.hoverDark}",
        "$type": "color"
      },
      "backgroundFocus": {
        "$value": "{semantic.color.surface.default}",
        "$type": "color"
      },
      "text": {
        "$value": "{semantic.color.surface.default}",
        "$type": "color"
      },
      "textFocus": {
        "$value": "{semantic.color.text.primary}",
        "$type": "color"
      },
      "placeholder": {
        "$value": "{semantic.color.surface.default}",
        "$type": "color"
      },
      "placeholderFocus": {
        "$value": "{semantic.color.text.tertiary}",
        "$type": "color"
      },
      "icon": {
        "$value": "{semantic.color.surface.default}",
        "$type": "color"
      },
      "iconFocus": {
        "$value": "{semantic.color.text.secondary}",
        "$type": "color"
      },
      "border": {
        "$value": "transparent",
        "$type": "color"
      },
      "borderFocus": {
        "$value": "{semantic.color.border.brand}",
        "$type": "color"
      },
      "height": {
        "$value": "40px",
        "$type": "dimension"
      },
      "paddingH": {
        "$value": "12px",
        "$type": "dimension"
      },
      "radius": {
        "$value": "4px",
        "$type": "borderRadius"
      },
      "typography": {
        "$value": {
          "fontFamily": "Source Sans Pro",
          "fontWeight": 400,
          "fontSize": "14px"
        },
        "$type": "typography"
      }
    },

    "icon": {
      "$description": "Action icons in top nav (cart, bell, help, etc.)",
      "default": {
        "color": {
          "$value": "{semantic.color.surface.default}",
          "$type": "color"
        },
        "background": {
          "$value": "transparent",
          "$type": "color"
        }
      },
      "hover": {
        "color": {
          "$value": "{semantic.color.surface.default}",
          "$type": "color"
        },
        "background": {
          "$value": "{semantic.color.interactive.hoverDark}",
          "$type": "color"
        }
      },
      "active": {
        "color": {
          "$value": "{semantic.color.surface.default}",
          "$type": "color"
        },
        "background": {
          "$value": "{semantic.color.interactive.hoverDark}",
          "$type": "color"
        }
      },
      "size": {
        "$value": "24px",
        "$type": "sizing"
      },
      "hitArea": {
        "$value": "40px",
        "$type": "sizing",
        "$description": "Minimum touch target wrapping the icon"
      },
      "radius": {
        "$value": "4px",
        "$type": "borderRadius"
      }
    },

    "badge": {
      "$description": "Notification count badge on cart / bell icons",
      "background": {
        "$value": "{semantic.color.feedback.danger}",
        "$type": "color"
      },
      "text": {
        "$value": "{semantic.color.surface.default}",
        "$type": "color"
      },
      "size": {
        "$value": "18px",
        "$type": "sizing"
      },
      "radius": {
        "$value": "100px",
        "$type": "borderRadius"
      },
      "typography": {
        "$value": {
          "fontFamily": "Source Sans Pro",
          "fontWeight": 700,
          "fontSize": "10px"
        },
        "$type": "typography"
      }
    },

    "userMenu": {
      "$description": "User account button / avatar in top nav",
      "default": {
        "text": {
          "$value": "{semantic.color.surface.default}",
          "$type": "color"
        },
        "icon": {
          "$value": "{semantic.color.surface.default}",
          "$type": "color"
        },
        "background": {
          "$value": "transparent",
          "$type": "color"
        }
      },
      "hover": {
        "background": {
          "$value": "{semantic.color.interactive.hoverDark}",
          "$type": "color"
        }
      },
      "typography": {
        "$value": {
          "fontFamily": "Source Sans Pro",
          "fontWeight": 400,
          "fontSize": "14px"
        },
        "$type": "typography"
      },
      "radius": {
        "$value": "4px",
        "$type": "borderRadius"
      },
      "paddingH": {
        "$value": "8px",
        "$type": "dimension"
      },
      "height": {
        "$value": "40px",
        "$type": "dimension"
      }
    },

    "dropdown": {
      "$description": "Dropdown menu that appears below top nav items",
      "background": {
        "$value": "{semantic.color.surface.default}",
        "$type": "color"
      },
      "border": {
        "$value": "{semantic.color.border.default}",
        "$type": "color"
      },
      "shadow": {
        "$value": "{primitive.shadow.md}",
        "$type": "boxShadow"
      },
      "radius": {
        "$value": "4px",
        "$type": "borderRadius"
      },
      "paddingV": {
        "$value": "8px",
        "$type": "dimension"
      },
      "item": {
        "default": {
          "text": {
            "$value": "{semantic.color.text.primary}",
            "$type": "color"
          },
          "background": {
            "$value": "transparent",
            "$type": "color"
          }
        },
        "hover": {
          "text": {
            "$value": "{semantic.color.text.primary}",
            "$type": "color"
          },
          "background": {
            "$value": "{semantic.color.surface.subtle}",
            "$type": "color"
          }
        },
        "height": {
          "$value": "40px",
          "$type": "dimension"
        },
        "paddingH": {
          "$value": "16px",
          "$type": "dimension"
        },
        "typography": {
          "$value": {
            "fontFamily": "Source Sans Pro",
            "fontWeight": 400,
            "fontSize": "14px"
          },
          "$type": "typography"
        }
      }
    }
  }
}




