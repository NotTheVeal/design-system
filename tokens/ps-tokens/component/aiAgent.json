{
  "aiAgent": {
    "$description": "AI Agent — chat interface, context buttons, and error states. Figma: 'Ai Agent' page.",
    "chat": {
      "background":        { "$value": "{primitive.color.neutral.50}", "$type": "color" },
      "paddingV":          { "$value": "16px", "$type": "spacing" },
      "paddingH":          { "$value": "16px", "$type": "spacing" },
      "gap":               { "$value": "12px", "$type": "spacing" }
    },
    "message": {
      "user": {
        "background":      { "$value": "{semantic.color.brand.tint}", "$type": "color" },
        "text":            { "$value": "{semantic.color.text.primary}", "$type": "color" },
        "radius":          { "$value": "12px 12px 4px 12px", "$type": "borderRadius" }
      },
      "agent": {
        "background":      { "$value": "{semantic.color.surface.default}", "$type": "color" },
        "text":            { "$value": "{semantic.color.text.primary}", "$type": "color" },
        "border":          { "$value": "{semantic.color.border.default}", "$type": "color" },
        "borderWidth":     { "$value": "1px", "$type": "borderWidth" },
        "radius":          { "$value": "12px 12px 12px 4px", "$type": "borderRadius" }
      },
      "error": {
        "background":      { "$value": "{semantic.color.feedback.error.background}", "$type": "color" },
        "text":            { "$value": "{semantic.color.feedback.error.DEFAULT}", "$type": "color" },
        "border":          { "$value": "{semantic.color.feedback.error.DEFAULT}", "$type": "color" },
        "borderWidth":     { "$value": "1px", "$type": "borderWidth" },
        "radius":          { "$value": "8px", "$type": "borderRadius" }
      },
      "paddingV":          { "$value": "10px", "$type": "spacing" },
      "paddingH":          { "$value": "14px", "$type": "spacing" },
      "maxWidth":          { "$value": "80%", "$type": "sizing" },
      "fontSize":          { "$value": "14px", "$type": "fontSizes" },
      "lineHeight":        { "$value": "22px", "$type": "lineHeights" }
    },
    "input": {
      "background":        { "$value": "{semantic.color.surface.default}", "$type": "color" },
      "border":            { "$value": "{semantic.color.border.default}", "$type": "color" },
      "borderFocus":       { "$value": "{semantic.color.brand.primary}", "$type": "color" },
      "borderWidth":       { "$value": "1px", "$type": "borderWidth" },
      "radius":            { "$value": "8px", "$type": "borderRadius" },
      "paddingV":          { "$value": "10px", "$type": "spacing" },
      "paddingH":          { "$value": "14px", "$type": "spacing" },
      "minHeight":         { "$value": "44px", "$type": "sizing" },
      "maxHeight":         { "$value": "120px", "$type": "sizing" }
    },
    "contextButton": {
      "background":        { "$value": "{semantic.color.brand.tint}", "$type": "color" },
      "backgroundHover":   { "$value": "{semantic.color.brand.light}", "$type": "color" },
      "text":              { "$value": "{semantic.color.brand.primary}", "$type": "color" },
      "border":            { "$value": "{semantic.color.brand.primary}", "$type": "color" },
      "borderWidth":       { "$value": "1px", "$type": "borderWidth" },
      "radius":            { "$value": "100px", "$type": "borderRadius" },
      "paddingV":          { "$value": "4px", "$type": "spacing" },
      "paddingH":          { "$value": "12px", "$type": "spacing" },
      "fontSize":          { "$value": "12px", "$type": "fontSizes" },
      "fontWeight":        { "$value": "600", "$type": "fontWeights" }
    },
    "typingIndicator": {
      "color":             { "$value": "{semantic.color.text.tertiary}", "$type": "color" },
      "dotSize":           { "$value": "6px", "$type": "sizing" },
      "gap":               { "$value": "3px", "$type": "spacing" }
    }
  }
}




