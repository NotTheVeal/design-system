      },
      "border": {
        "$value": "#ec8000",
        "$type": "color"
      },
      "dash": {
        "$value": "{semantic.color.surface.default}",
        "$type": "color"
      }
    },
    "paddingInner": {
      "$value": "6px",
      "$type": "dimension"
    },
    "labelTypography": {
      "$value": {
        "fontFamily": "Source Sans Pro",
        "fontWeight": 400,
        "fontSize": "14px",
        "lineHeight": "20px"
      },
      "$type": "typography"
    },
    "gap": {
      "$value": "8px",
      "$type": "dimension"
    }
