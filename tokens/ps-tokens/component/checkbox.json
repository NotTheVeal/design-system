{
  "checkbox": {
    "$description": "Check Box \u2014 24\u00d724px. States: Default/Disabled/Selected/Completed (Check Boxes page)",
    "size": {
      "$value": "24px",
      "$type": "dimension"
    },
    "radius": {
      "$value": "2px",
      "$type": "borderRadius"
    },
    "strokeWidth": {
      "$value": "1.5px",
      "$type": "borderWidth"
    },
    "default": {
      "background": {
        "$value": "{semantic.color.surface.default}",
        "$type": "color"
      },
      "border": {
        "$value": "{primitive.color.neutral.400}",
        "$type": "color",
        "$description": "Figma: strk:#949494"
      },
      "checkmark": {
        "$value": "transparent",
        "$type": "color"
      }
    },
    "hover": {
      "background": {
        "$value": "{semantic.color.surface.default}",
        "$type": "color"
      },
      "border": {
        "$value": "{semantic.color.brand.primary}",
        "$type": "color"
      }
    },
    "selected": {
      "background": {
        "$value": "#ff9505",
        "$type": "color",
        "$description": "Figma exact: orange selected fill"
      },
      "border": {
        "$value": "#ec8000",
        "$type": "color",
        "$description": "Figma exact: orange selected stroke"
      },
      "checkmark": {
        "$value": "{semantic.color.surface.default}",
        "$type": "color"
      },
      "stroke": {
        "$value": "#ec8000",
        "$type": "color"
      },
      "strokeWidth": {
        "$value": "1.5px",
        "$type": "borderWidth",
        "$description": "Figma: sw:1.5"
      }
    },
    "completed": {
      "background": {
        "$value": "{semantic.color.surface.default}",
        "$type": "color"
      },
      "border": {
        "$value": "{semantic.color.feedback.success.DEFAULT}",
        "$type": "color"
      },
      "checkmark": {
        "$value": "{semantic.color.feedback.success.DEFAULT}",
        "$type": "color"
      }
    },
    "disabled": {
      "background": {
        "$value": "{primitive.color.neutral.300}",
        "$type": "color",
        "$description": "Figma: #cccccc"
      },
      "border": {
        "$value": "{primitive.color.neutral.400}",
        "$type": "color",
        "$description": "Figma: strk:#949494"
      },
      "inner": {
        "$value": "{semantic.color.text.disabled}",
        "$type": "color"
      },
      "checkmark": {
        "$value": "transparent",
        "$type": "color"
      }
    },
    "focus": {
      "shadow": {
        "$value": "0 0 10px 5px rgba(0,91,166,0.5)",
