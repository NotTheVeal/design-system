{
  "badge": {
    "$description": "Badges — verified against Figma 'Badges' page. 3 component sets: Assignment Status, Status Badges, List Badges.",

    "assignmentStatus": {
      "$description": "Assignment Status Badges — fill:#fffbf2, stroke:#ffb000, radius:3. States: Not Started, In Progress, In Progress #%, Completed",
      "background":    { "$value": "#fffbf2", "$type": "color", "$description": "Figma exact" },
      "border":        { "$value": "#ffb000", "$type": "color", "$description": "Figma exact: amber stroke" },
      "borderWidth":   { "$value": "1px", "$type": "borderWidth" },
      "radius":        { "$value": "3px", "$type": "borderRadius", "$description": "Figma: r:3" },
      "text":          { "$value": "#1e1e1e", "$type": "color", "$description": "Figma exact" },
      "fontSize":      { "$value": "12px", "$type": "fontSizes" },
      "fontWeight":    { "$value": "700", "$type": "fontWeights" },
      "height":        { "$value": "26px", "$type": "sizing" },
      "paddingH":      { "$value": "8px", "$type": "spacing" }
    },

    "status": {
      "$description": "Status Badges — radius:4, 20px tall, 12px SemiBold. States: Processing, Shipped, Pending, Under Contract",
      "radius":        { "$value": "4px", "$type": "borderRadius", "$description": "Figma: r:4" },
      "height":        { "$value": "20px", "$type": "sizing" },
      "fontSize":      { "$value": "12px", "$type": "fontSizes" },
      "fontWeight":    { "$value": "600", "$type": "fontWeights" },
      "paddingH":      { "$value": "6px", "$type": "spacing" },
      "processing": {
        "background":  { "$value": "#e5e5e5", "$type": "color", "$description": "Figma exact" },
        "text":        { "$value": "#525252", "$type": "color", "$description": "Figma exact" }
      },
      "shipped": {
        "background":  { "$value": "#bfdbfe", "$type": "color", "$description": "Figma exact — light blue" },
        "text":        { "$value": "#1d4ed8", "$type": "color", "$description": "Figma exact — blue-700" }
      },
      "pending": {
        "background":  { "$value": "#bfdbfe", "$type": "color" },
        "text":        { "$value": "#1d4ed8", "$type": "color" }
      },
      "underContract": {
        "background":  { "$value": "#bfdbfe", "$type": "color" },
        "text":        { "$value": "#1d4ed8", "$type": "color" }
      }
    },

    "list": {
      "$description": "List type pill badges — radius:40 (pill), uppercase, 12px Bold, 27px tall. Colors: purple, blue, red, green, orange, gray",
      "radius":        { "$value": "40px", "$type": "borderRadius", "$description": "Figma: r:40 pill" },
      "height":        { "$value": "27px", "$type": "sizing" },
      "fontSize":      { "$value": "12px", "$type": "fontSizes" },
      "fontWeight":    { "$value": "700", "$type": "fontWeights" },
      "letterSpacing": { "$value": "0.5px", "$type": "letterSpacing" },
      "textTransform": { "$value": "uppercase", "$type": "textCase" },
      "paddingH":      { "$value": "10px", "$type": "spacing" },
      "purple": {
        "background":  { "$value": "#ede5fc", "$type": "color", "$description": "Figma exact" },
        "text":        { "$value": "#753ec7", "$type": "color", "$description": "Figma exact" }
      },
      "blue": {
        "background":  { "$value": "#e0efff", "$type": "color", "$description": "Figma exact" },
        "text":        { "$value": "#0e72c7", "$type": "color", "$description": "Figma exact" }
      },
      "red": {
        "background":  { "$value": "#ffe1d9", "$type": "color", "$description": "Figma exact" },
        "text":        { "$value": "#c73d19", "$type": "color", "$description": "Figma exact" }
      },
      "green": {
        "background":  { "$value": "{semantic.color.feedback.alertSuccessBg}", "$type": "color" },
        "text":        { "$value": "{semantic.color.feedback.successDark}", "$type": "color" }
      },
      "orange": {
        "background":  { "$value": "#fff0d9", "$type": "color" },
        "text":        { "$value": "#b45309", "$type": "color" }
      },
      "gray": {
        "background":  { "$value": "{primitive.color.neutral.100}", "$type": "color" },
        "text":        { "$value": "{semantic.color.text.secondary}", "$type": "color" }
      }
    },

    "shared": {
      "borderWidth":   { "$value": "1px", "$type": "borderWidth" }
    }
  }
}





