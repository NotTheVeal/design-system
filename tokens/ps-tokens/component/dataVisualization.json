{
  "dataVisualization": {
    "$description": "Data Visualization tokens — shared palette + per-chart-type overrides. Covers all 15 chart families in the Figma Data Visualization section.",

    "color": {
      "series": {
        "1": { "$value": "{semantic.color.brand.primary}",   "$type": "color", "$description": "#005BA6 — PS Blue" },
        "2": { "$value": "{semantic.color.brand.light}",     "$type": "color", "$description": "#009CF4 — Azure Blue" },
        "3": { "$value": "{primitive.color.teal.500}",       "$type": "color", "$description": "Teal accent" },
        "4": { "$value": "{semantic.color.brand.secondary}", "$type": "color", "$description": "#002F48 — Midnight" },
        "5": { "$value": "{primitive.color.blue.100}",       "$type": "color", "$description": "Light blue" },
        "6": { "$value": "{primitive.color.blue.50}",        "$type": "color", "$description": "Faintest blue" },
        "7": { "$value": "{primitive.color.green.500}",      "$type": "color", "$description": "Success green" },
        "8": { "$value": "{primitive.color.amber.400}",      "$type": "color", "$description": "Amber" }
      },
      "feedback": {
        "success": { "$value": "{semantic.color.feedback.success.DEFAULT}", "$type": "color" },
        "warning":  { "$value": "{semantic.color.feedback.warning.DEFAULT}", "$type": "color" },
        "error":    { "$value": "{semantic.color.feedback.error.DEFAULT}",   "$type": "color" },
        "info":     { "$value": "{semantic.color.brand.light}",      "$type": "color" }
      },
      "axis":       { "$value": "{semantic.color.border.default}",  "$type": "color" },
      "grid":       { "$value": "{semantic.color.surface.subtle}",  "$type": "color" },
      "axisLabel":  { "$value": "{semantic.color.text.tertiary}",   "$type": "color" },
      "background": { "$value": "{semantic.color.surface.default}", "$type": "color" },
      "empty":      { "$value": "{primitive.color.neutral.100}",    "$type": "color" }
    },

    "tooltip": {
      "background": { "$value": "{semantic.color.surface.default}", "$type": "color" },
      "border":     { "$value": "{semantic.color.border.default}",  "$type": "color" },
      "text":       { "$value": "{semantic.color.text.primary}",    "$type": "color" },
      "label":      { "$value": "{semantic.color.text.secondary}",  "$type": "color" },
      "shadow":     { "$value": "{semantic.shadow.md}",             "$type": "boxShadow" }
    },

    "legend": {
      "text":     { "$value": "{semantic.color.text.primary}",         "$type": "color" },
      "fontSize": { "$value": "{semantic.typography.body.sm.fontSize}", "$type": "fontSizes" }
    },

    "typography": {
      "axisLabel": {
        "fontSize":   { "$value": "{semantic.typography.body.xs.fontSize}",        "$type": "fontSizes" },
        "fontWeight": { "$value": "{primitive.typography.fontWeight.regular}",     "$type": "fontWeights" },
        "color":      { "$value": "{semantic.color.text.tertiary}",                "$type": "color" }
      },
      "title": {
        "fontSize":   { "$value": "{semantic.typography.body.sm.fontSize}",        "$type": "fontSizes" },
        "fontWeight": { "$value": "{primitive.typography.fontWeight.semiBold}",    "$type": "fontWeights" },
        "color":      { "$value": "{semantic.color.text.primary}",                 "$type": "color" }
      },
      "value": {
        "fontSize":   { "$value": "{semantic.typography.body.xs.fontSize}",        "$type": "fontSizes" },
        "fontWeight": { "$value": "{primitive.typography.fontWeight.regular}",     "$type": "fontWeights" }
      }
    },

    "spacing": {
      "marginTop":    { "$value": "50px", "$type": "spacing" },
      "marginRight":  { "$value": "60px", "$type": "spacing" },
      "marginBottom": { "$value": "50px", "$type": "spacing" },
      "marginLeft":   { "$value": "60px", "$type": "spacing" },
      "padding":      { "$value": "16px", "$type": "spacing" },
      "gap":          { "$value": "8px",  "$type": "spacing" }
    },

    "border": {
      "radius": { "$value": "4px",  "$type": "borderRadius" },
      "width":  { "$value": "1px",  "$type": "borderWidth" },
      "color":  { "$value": "{semantic.color.border.default}", "$type": "color" }
    },

    "motion": {
      "config":   { "$value": "gentle", "$type": "other" },
      "duration": { "$value": "{semantic.motion.duration.normal}", "$type": "other" }
    },

    "bar": {
      "$description": "Bar Charts — Horizontal, Stacked, Vertical, Grouped",
      "color":           { "$value": "{semantic.color.brand.primary}", "$type": "color" },
      "borderRadius":    { "$value": "2px",   "$type": "borderRadius" },
      "padding":         { "$value": "0.3",   "$type": "other", "$description": "Nivo innerPadding ratio" },
      "labelColor":      { "$value": "#ffffff","$type": "color" },
      "labelSkipHeight": { "$value": "12px",  "$type": "sizing" }
    },

    "line": {
      "$description": "Line & Area Charts — Line, Multi-Line, Area, Stacked Area",
      "width":         { "$value": "2.5px", "$type": "borderWidth" },
      "activeWidth":   { "$value": "4px",   "$type": "borderWidth" },
      "dotSize":       { "$value": "8px",   "$type": "sizing" },
      "dotBorderWidth":{ "$value": "2px",   "$type": "borderWidth" },
      "areaOpacity":   { "$value": "0.2",   "$type": "opacity" }
    },

    "pie": {
      "$description": "Pie · Donut · Waffle — Pie, Donut, Multi-Ring, Exploded Pie, Waffle, Gauge",
      "innerRadius":       { "$value": "0",    "$type": "other", "$description": "0 = full pie; set to 0.6 for donut" },
      "donutInnerRadius":  { "$value": "0.6",  "$type": "other" },
      "multiRingGap":      { "$value": "0.05", "$type": "other", "$description": "Gap between rings" },
      "padAngle":          { "$value": "0.02", "$type": "other" },
      "cornerRadius":      { "$value": "2px",  "$type": "borderRadius" },
      "waffle": {
        "total":    { "$value": "100",  "$type": "other" },
        "rows":     { "$value": "10",   "$type": "other" },
        "columns":  { "$value": "10",   "$type": "other" },
        "padding":  { "$value": "2px",  "$type": "spacing" }
      },
      "gauge": {
        "startAngle":   { "$value": "-90",  "$type": "other" },
        "endAngle":     { "$value": "90",   "$type": "other" },
        "innerRadius":  { "$value": "0.6",  "$type": "other" },
        "trackColor":   { "$value": "{primitive.color.neutral.100}", "$type": "color" }
      }
    },

    "scatter": {
      "$description": "Scatter · Bubble · Radar — Scatter Plot, Bubble Chart, Radar Chart, Radar + Scatter Combo",
      "dotSize":        { "$value": "8px",  "$type": "sizing" },
      "dotBorderWidth": { "$value": "1px",  "$type": "borderWidth" },
      "dotColor":       { "$value": "{semantic.color.brand.primary}", "$type": "color" },
      "bubble": {
        "minSize": { "$value": "6px",  "$type": "sizing" },
        "maxSize": { "$value": "80px", "$type": "sizing" }
      },
      "radar": {
        "fillOpacity":    { "$value": "0.15", "$type": "opacity" },
        "dotSize":        { "$value": "8px",  "$type": "sizing" },
        "dotBorderWidth": { "$value": "2px",  "$type": "borderWidth" },
        "gridLabelOffset":{ "$value": "16px", "$type": "spacing" }
      }
    },

    "heatmap": {
      "$description": "Heatmap — Time Pattern Heatmap, Correlation Matrix",
      "emptyColor":       { "$value": "{primitive.color.neutral.100}", "$type": "color" },
      "cellBorderRadius": { "$value": "2px", "$type": "borderRadius" },
      "cellBorderWidth":  { "$value": "1px", "$type": "borderWidth" },
      "cellBorderColor":  { "$value": "{semantic.color.border.default}", "$type": "color" }
    },

    "funnel": {
      "$description": "Funnel · Treemap — Funnel Chart, Treemap",
      "funnel": {
        "labelColor":       { "$value": "#ffffff", "$type": "color" },
        "borderWidth":      { "$value": "2px",     "$type": "borderWidth" },
        "borderOpacity":    { "$value": "0.5",     "$type": "opacity" }
      },
      "treemap": {
        "labelSkipSize":    { "$value": "12px", "$type": "sizing" },
        "outerPadding":     { "$value": "3px",  "$type": "spacing" },
        "innerPadding":     { "$value": "3px",  "$type": "spacing" },
        "borderWidth":      { "$value": "0px",  "$type": "borderWidth" }
      }
    },

    "bump": {
      "$description": "Bump · Stream — Bump Chart, Stream Chart",
      "bump": {
        "lineWidth":       { "$value": "3px",  "$type": "borderWidth" },
        "activeLineWidth": { "$value": "6px",  "$type": "borderWidth" },
        "pointSize":       { "$value": "10px", "$type": "sizing" },
        "activeBorderWidth":{ "$value": "3px", "$type": "borderWidth" }
      },
      "stream": {
        "offsetType":  { "$value": "wiggle", "$type": "other" },
        "fillOpacity": { "$value": "0.85",   "$type": "opacity" },
        "borderWidth": { "$value": "0px",    "$type": "borderWidth" }
      }
    },

    "sankey": {
      "$description": "Sankey · Chord — Sankey Diagram, Chord Diagram",
      "sankey": {
        "nodeWidth":    { "$value": "18px", "$type": "sizing" },
        "nodePadding":  { "$value": "12px", "$type": "spacing" },
        "linkOpacity":  { "$value": "0.5",  "$type": "opacity" },
        "nodeOpacity":  { "$value": "1",    "$type": "opacity" },
        "nodeColor":    { "$value": "{semantic.color.brand.primary}", "$type": "color" }
      },
      "chord": {
        "padAngle":     { "$value": "0.02", "$type": "other" },
        "innerRadiusRatio": { "$value": "0.96", "$type": "other" },
        "ribbonOpacity":    { "$value": "0.6",  "$type": "opacity" },
        "ribbonBlendMode":  { "$value": "multiply", "$type": "other" }
      }
    },

    "calendar": {
      "$description": "Calendar · Swarm Plot — Calendar Heatmap, Swarm Plot",
      "calendar": {
        "emptyColor":     { "$value": "{primitive.color.neutral.100}", "$type": "color" },
        "dayBorderColor": { "$value": "#ffffff", "$type": "color" },
        "dayBorderWidth": { "$value": "2px",     "$type": "borderWidth" },
        "monthBorderColor":{ "$value": "{semantic.color.border.default}", "$type": "color" }
      },
      "swarm": {
        "dotSize":        { "$value": "8px",  "$type": "sizing" },
        "spacing":        { "$value": "2px",  "$type": "spacing" },
        "borderWidth":    { "$value": "1px",  "$type": "borderWidth" }
      }
    },

    "sunburst": {
      "$description": "Sunburst · Circle Packing — Sunburst Chart, Circle Packing",
      "sunburst": {
        "cornerRadius":   { "$value": "2px",  "$type": "borderRadius" },
        "borderWidth":    { "$value": "1px",  "$type": "borderWidth" },
        "borderColor":    { "$value": "#ffffff", "$type": "color" }
      },
      "circlePacking": {
        "padding":        { "$value": "4px",  "$type": "spacing" },
        "leavesOnly":     { "$value": "false", "$type": "other" },
        "borderWidth":    { "$value": "1px",  "$type": "borderWidth" },
        "borderColor":    { "$value": "#ffffff", "$type": "color" }
      }
    },

    "parallel": {
      "$description": "Parallel Coords · Network — Parallel Coordinates, Network Graph",
      "parallelCoords": {
        "lineWidth":        { "$value": "1.5px", "$type": "borderWidth" },
        "lineOpacity":      { "$value": "0.6",   "$type": "opacity" },
        "axisLineColor":    { "$value": "{semantic.color.border.strong}", "$type": "color" }
      },
      "network": {
        "nodeBorderWidth":  { "$value": "2px",  "$type": "borderWidth" },
        "linkThickness":    { "$value": "1px",  "$type": "borderWidth" },
        "linkColor":        { "$value": "{semantic.color.border.default}", "$type": "color" },
        "repulsivity":      { "$value": "6",    "$type": "other" }
      }
    },

    "boxPlot": {
      "$description": "Box Plot · Marimekko — Box Plot, Marimekko Chart",
      "box": {
        "whiskerWidth":   { "$value": "1px",  "$type": "borderWidth" },
        "medianWidth":    { "$value": "2px",  "$type": "borderWidth" },
        "outlierSize":    { "$value": "6px",  "$type": "sizing" },
        "fillOpacity":    { "$value": "0.7",  "$type": "opacity" }
      },
      "marimekko": {
        "innerPadding":   { "$value": "2px",  "$type": "spacing" },
        "outerPadding":   { "$value": "4px",  "$type": "spacing" },
        "labelSkipWidth": { "$value": "30px", "$type": "sizing" }
      }
    },

    "geo": {
      "$description": "Geo & Choropleth — US Regions Map, Choropleth Map",
      "borderColor":      { "$value": "#ffffff",  "$type": "color" },
      "borderWidth":      { "$value": "0.5px",    "$type": "borderWidth" },
      "unknownColor":     { "$value": "{primitive.color.neutral.200}", "$type": "color" },
      "projectionScale":  { "$value": "100",       "$type": "other" }
    },

    "voronoi": {
      "$description": "Voronoi Diagram — Voronoi Diagram, Filled Zone Voronoi",
      "fillOpacity":      { "$value": "0.25", "$type": "opacity" },
      "borderWidth":      { "$value": "1px",  "$type": "borderWidth" },
      "borderColor":      { "$value": "{semantic.color.border.default}", "$type": "color" },
      "pointSize":        { "$value": "6px",  "$type": "sizing" }
    },

    "bullet": {
      "$description": "Bullet Chart — Bullet Chart, Multi-Row Bullet",
      "rangeColors": {
        "1": { "$value": "{primitive.color.neutral.200}", "$type": "color", "$description": "Worst range" },
        "2": { "$value": "{primitive.color.neutral.300}", "$type": "color", "$description": "Middle range" },
        "3": { "$value": "{primitive.color.neutral.400}", "$type": "color", "$description": "Best range" }
      },
      "measureColor":   { "$value": "{semantic.color.brand.primary}", "$type": "color" },
      "markerColor":    { "$value": "{semantic.color.text.primary}",  "$type": "color" },
      "markerWidth":    { "$value": "4px",  "$type": "borderWidth" },
      "titleWidth":     { "$value": "120px","$type": "sizing" }
    }
  }
}
