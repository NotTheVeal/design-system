        "3": { "$value": "{primitive.color.blue.300}", "$type": "color" },
        "4": { "$value": "{semantic.color.brand.secondary}", "$type": "color" },
        "5": { "$value": "{primitive.color.blue.100}", "$type": "color" },
        "6": { "$value": "{primitive.color.blue.50}", "$type": "color" }
      },
      "feedback": {
        "success": { "$value": "{semantic.color.feedback.success}", "$type": "color" },
