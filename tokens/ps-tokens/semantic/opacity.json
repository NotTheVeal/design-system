{
  "semantic": {
    "opacity": {
      "disabled": {
        "$value": "{primitive.opacity.40}",
        "$type": "opacity",
        "$description": "Disabled state — applied to entire disabled component"
      },
      "overlay": {
        "$value": "{primitive.opacity.50}",
        "$type": "opacity",
        "$description": "Modal backdrop / page scrim"
      },
      "hover": {
        "$value": "{primitive.opacity.80}",
        "$type": "opacity",
        "$description": "Subtle hover fade on images or ghost elements"
      },
      "invisible": {
        "$value": "{primitive.opacity.0}",
        "$type": "opacity",
        "$description": "Fully transparent — visually hidden but present in DOM"
      },
      "visible": {
        "$value": "{primitive.opacity.100}",
        "$type": "opacity",
        "$description": "Fully opaque — default visible state"
      }
    }
  }
}
