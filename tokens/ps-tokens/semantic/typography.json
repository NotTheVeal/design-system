{
  "semantic": {
    "typography": {
      "body": {
        "xs": {
          "fontSize":   { "$value": "12px", "$type": "fontSizes",   "$description": "Caption / label text" },
          "fontWeight": { "$value": "{primitive.typography.fontWeight.regular}", "$type": "fontWeights" },
          "lineHeight": { "$value": "1.4",  "$type": "lineHeights" }
        },
        "sm": {
          "fontSize":   { "$value": "14px", "$type": "fontSizes",   "$description": "Small body / secondary text" },
          "fontWeight": { "$value": "{primitive.typography.fontWeight.regular}", "$type": "fontWeights" },
          "lineHeight": { "$value": "1.5",  "$type": "lineHeights" }
        },
        "md": {
          "fontSize":   { "$value": "16px", "$type": "fontSizes",   "$description": "Default body text" },
          "fontWeight": { "$value": "{primitive.typography.fontWeight.regular}", "$type": "fontWeights" },
          "lineHeight": { "$value": "1.5",  "$type": "lineHeights" }
        },
        "lg": {
          "fontSize":   { "$value": "18px", "$type": "fontSizes",   "$description": "Large body text" },
          "fontWeight": { "$value": "{primitive.typography.fontWeight.regular}", "$type": "fontWeights" },
          "lineHeight": { "$value": "1.6",  "$type": "lineHeights" }
        }
      },
      "display": {
        "xs": {
          "fontSize":   { "$value": "20px", "$type": "fontSizes" },
          "fontWeight": { "$value": "{primitive.typography.fontWeight.light}", "$type": "fontWeights" }
        },
        "sm": {
          "fontSize":   { "$value": "24px", "$type": "fontSizes" },
          "fontWeight": { "$value": "{primitive.typography.fontWeight.light}", "$type": "fontWeights" }
        },
        "md": {
          "fontSize":   { "$value": "30px", "$type": "fontSizes" },
          "fontWeight": { "$value": "{primitive.typography.fontWeight.light}", "$type": "fontWeights" }
        },
        "lg": {
          "fontSize":   { "$value": "36px", "$type": "fontSizes" },
          "fontWeight": { "$value": "{primitive.typography.fontWeight.light}", "$type": "fontWeights" }
        },
        "xl": {
          "fontSize":   { "$value": "48px", "$type": "fontSizes" },
          "fontWeight": { "$value": "{primitive.typography.fontWeight.light}", "$type": "fontWeights" }
        }
      },
      "heading": {
        "h1": { "fontSize": { "$value": "48px", "$type": "fontSizes" }, "fontWeight": { "$value": "{primitive.typography.fontWeight.light}", "$type": "fontWeights" } },
        "h2": { "fontSize": { "$value": "36px", "$type": "fontSizes" }, "fontWeight": { "$value": "{primitive.typography.fontWeight.light}", "$type": "fontWeights" } },
        "h3": { "fontSize": { "$value": "30px", "$type": "fontSizes" }, "fontWeight": { "$value": "{primitive.typography.fontWeight.light}", "$type": "fontWeights" } },
        "h4": { "fontSize": { "$value": "24px", "$type": "fontSizes" }, "fontWeight": { "$value": "{primitive.typography.fontWeight.semiBold}", "$type": "fontWeights" } },
        "h5": { "fontSize": { "$value": "20px", "$type": "fontSizes" }, "fontWeight": { "$value": "{primitive.typography.fontWeight.semiBold}", "$type": "fontWeights" } },
        "h6": { "fontSize": { "$value": "16px", "$type": "fontSizes" }, "fontWeight": { "$value": "{primitive.typography.fontWeight.semiBold}", "$type": "fontWeights" } }
      },
      "label": {
        "sm": {
          "fontSize":   { "$value": "12px", "$type": "fontSizes" },
          "fontWeight": { "$value": "{primitive.typography.fontWeight.semiBold}", "$type": "fontWeights" }
        },
        "md": {
          "fontSize":   { "$value": "14px", "$type": "fontSizes" },
          "fontWeight": { "$value": "{primitive.typography.fontWeight.semiBold}", "$type": "fontWeights" }
        }
      }
    }
  }
}
