          "$type": "other"
        }
      },
      "radius": {
        "none": {
          "$value": "{primitive.radius.none}",
          "$type": "borderRadius"
        },
        "sm": {
          "$value": "{primitive.radius.sm}",
          "$type": "borderRadius",
