        },
        "md": {
          "$value": "{primitive.radius.md}",
          "$type": "borderRadius"
        },
        "lg": {
          "$value": "{primitive.radius.lg}",
          "$type": "borderRadius"
        },
        "full": {
          "$value": "{primitive.radius.full}",
          "$type": "borderRadius",
          "$description": "Pills, chips, badges"
        }
      }
